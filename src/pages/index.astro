---
import BaseLayout from "../layouts/BaseLayout.astro";
import LeadForm from "../components/LeadForm.astro";
import SectionIntro from "../components/SectionIntro.astro";
import {
  CalendarCheck,
  CheckCircle2,
  Fan,
  Gauge,
  Home,
  ShieldCheck,
  Snowflake,
  Star,
  ThermometerSun,
  Wrench,
} from "@lucide/astro";

const services = [
  {
    icon: Snowflake,
    title: "Airco installeren aan huis",
    text: "Advies en montage van een passende split-airco voor woonkamer, slaapkamer, kantoor of meerdere ruimtes.",
  },
  {
    icon: Gauge,
    title: "Koelvermogen berekenen",
    text: "We kijken naar ruimtegrootte, isolatie, ligging en gebruik zodat de airco niet te licht of te zwaar is.",
  },
  {
    icon: Wrench,
    title: "Airco onderhoud en service",
    text: "Controle, reiniging en onderhoud zodat je airco stil, zuinig en betrouwbaar blijft werken.",
  },
];

const benefits = [
  "Duidelijk advies vooraf",
  "Netjes gemonteerd door ervaren monteur",
  "Geschikt voor koelen en verwarmen",
  "Advies voor woonkamer, slaapkamer of kantoor",
  "Uitleg over bediening en onderhoud",
  "Ook geschikt voor Daikin airco advies",
];

const process = [
  {
    title: "Aanvraag",
    text: "Je vult kort je woning, ruimte en contactgegevens in.",
  },
  {
    title: "Advies",
    text: "We bekijken welke airco en welk vermogen past.",
  },
  {
    title: "Offerte",
    text: "Je ontvangt een duidelijke prijs en planning.",
  },
  {
    title: "Installatie",
    text: "De monteur plaatst de airco en geeft uitleg.",
  },
];

const reviews = [
  {
    name: "Peter uit Amersfoort",
    text: "Duidelijke uitleg over het juiste vermogen en geen verrassingen achteraf. De airco hangt netjes.",
  },
  {
    name: "Marianne uit Haarlem",
    text: "Prettig contact, normale offerte en de monteur werkte rustig en schoon.",
  },
  {
    name: "Erik uit Breda",
    text: "Goed geholpen met advies voor de slaapkamer en woonkamer. Alles werkt stil en snel.",
  },
];

const faqs = [
  {
    q: "Welke airco heb ik nodig voor mijn woning?",
    a: "Dat hangt af van de ruimte, isolatie, zonligging en gewenste functies. Daarom vragen we eerst kort je situatie uit.",
  },
  {
    q: "Wat kost een airco laten installeren?",
    a: "De prijs hangt af van het type airco, het vermogen, de leidingroute en de plek van de binnen- en buitenunit. Daarom geven we eerst advies en een duidelijke prijsindicatie.",
  },
  {
    q: "Kan een airco ook verwarmen?",
    a: "Ja. Veel moderne split-airco's kunnen naast koelen ook efficiënt verwarmen. We adviseren wat past bij jouw gebruik.",
  },
  {
    q: "Is de aanvraag vrijblijvend?",
    a: "Ja. Je ontvangt eerst advies en een duidelijke prijsindicatie. Je zit nergens aan vast.",
  },
];

const siteUrl = Astro.site ?? Astro.url.origin;
const pageUrl = new URL("/", siteUrl).toString();
const businessId = new URL("/#bedrijf", siteUrl).toString();
const pageSchema = [
  {
    "@type": "Service",
    "@id": new URL("/#airco-installatie", siteUrl).toString(),
    name: "Airco laten installeren aan huis",
    serviceType: "Airco installatie, advies en onderhoud",
    areaServed: "Nederland",
    provider: { "@id": businessId },
    url: pageUrl,
    description: "Airco advies en installatie voor particuliere woningen en kleinzakelijke adressen, inclusief koelvermogen berekenen, montage en onderhoud.",
    offers: {
      "@type": "Offer",
      availability: "https://schema.org/InStock",
      priceCurrency: "EUR",
      url: new URL("/#offerte", siteUrl).toString(),
    },
  },
  {
    "@type": "BreadcrumbList",
    "@id": new URL("/#breadcrumb", siteUrl).toString(),
    itemListElement: [
      {
        "@type": "ListItem",
        position: 1,
        name: "Home",
        item: pageUrl,
      },
    ],
  },
];
---

<BaseLayout
  title="Airco laten installeren aan huis | Koelzeker Klimaatspecialist"
  description="Airco laten installeren? Vraag gratis advies aan voor airco installatie aan huis, onderhoud en vervanging. Duidelijke prijs, nette montage en persoonlijk advies."
  canonical="/"
  schema={pageSchema}
>
  <section id="top" class="relative overflow-hidden bg-brand-navy">
    <img
      src="/images/airco-hero-v2.webp"
      alt="Airco installateur monteert een split-airco aan huis"
      class="absolute inset-0 h-full w-full object-cover opacity-35"
      loading="eager"
      fetchpriority="high"
    />
    <div class="absolute inset-0 bg-brand-navy/70"></div>
    <div class="container-page relative grid gap-8 py-10 md:py-14 lg:grid-cols-[1fr_420px] lg:items-center">
      <div class="text-white">
        <p class="mb-3 text-[14px] font-semibold uppercase text-white">Airco installatie en advies</p>
        <h1 class="max-w-[650px] text-[34px] font-bold leading-tight sm:text-[42px] md:text-[48px]">
          Airco laten installeren aan huis
        </h1>
        <p class="mt-5 max-w-[590px] text-[17px] leading-8 text-white">
          Voor particuliere woningen en kleine bedrijven. Koelzeker adviseert over de juiste airco, berekent het benodigde vermogen en zorgt voor nette montage, onderhoud en uitleg.
        </p>
        <div class="mt-7">
          <a href="#offerte" class="btn-primary cta-focus">Vraag advies aan</a>
        </div>
        <p class="mt-6 text-[14px] text-white">
          Vrijblijvend advies • Duidelijke prijs • Installatie door ervaren monteurs
        </p>
      </div>
      <LeadForm compact={true} dark={true} />
    </div>
  </section>

  <section id="diensten" class="bg-white section-pad">
    <div class="container-page">
      <SectionIntro
        eyebrow="Onze diensten"
        title="Airco installatie, onderhoud en advies"
        text="Geen ingewikkelde verkooppraat, maar duidelijk advies over wat in jouw woning of bedrijfspand werkt."
      />

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {services.map((service) => {
          const Icon = service.icon;
          return (
            <article class="service-card cable-corner p-6">
              <div class="mb-4 flex items-center gap-3">
                <Icon size={24} class="text-brand-blue" aria-hidden="true" />
                <h3 class="text-[20px] font-bold text-brand-deep">{service.title}</h3>
              </div>
              <p class="text-[15px] leading-7 text-black">{service.text}</p>
            </article>
          );
        })}
      </div>

      <div class="mt-7">
        <a href="#offerte" class="btn-primary cta-focus">Vraag advies aan</a>
      </div>
    </div>
  </section>

  <section id="voordelen" class="bg-brand-soft section-pad">
    <div class="container-page grid items-center gap-9 lg:grid-cols-[0.95fr_1fr]">
      <div>
        <img
          src="/images/airco-buitenunit-v2.webp"
          alt="Airco monteur controleert buitenunit bij een woning"
          class="h-[390px] w-full rounded-[4px] object-cover"
          loading="lazy"
        />
      </div>
      <div>
        <SectionIntro
          eyebrow="Waarom kiezen voor ons"
          title="Een airco moet passen bij de ruimte, niet alleen bij de prijs"
          text="Een goede airco werkt stil, zuinig en comfortabel. Daarom kijken we naar de ruimte, isolatie, zonligging en hoe je de airco wilt gebruiken."
        />
        <div class="mt-6 grid gap-x-6 gap-y-3 sm:grid-cols-2">
          {benefits.map((benefit) => (
            <p class="flex items-start gap-2 text-[15px] font-medium text-black">
              <CheckCircle2 size={18} class="mt-0.5 shrink-0 text-brand-orange" aria-hidden="true" />
              {benefit}
            </p>
          ))}
        </div>
        <div class="mt-7">
          <a href="#offerte" class="btn-primary cta-focus">Vraag advies aan</a>
        </div>
      </div>
    </div>
  </section>

  <section id="werkwijze" class="bg-white section-pad">
    <div class="container-page">
      <SectionIntro
        eyebrow="Werkwijze"
        title="Zo verloopt een airco-installatie"
        text="Een overzichtelijke aanpak, zoals je van een lokale installateur mag verwachten."
        centered={true}
      />

      <div class="mt-8 grid gap-5 md:grid-cols-4">
        {process.map((step, index) => (
          <article class="service-card cable-corner p-5">
            <div class="mb-4 inline-flex h-9 w-9 items-center justify-center rounded-[4px] bg-brand-blue text-[15px] font-bold text-white">
              {index + 1}
            </div>
            <h3 class="text-[18px] font-bold text-brand-deep">{step.title}</h3>
            <p class="mt-2 text-[14px] leading-6 text-black">{step.text}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand-soft section-pad">
    <div class="container-page grid items-center gap-9 lg:grid-cols-[1fr_0.85fr]">
      <div>
        <SectionIntro
          eyebrow="Technisch advies"
          title="Airco kiezen voor koelen, verwarmen en comfort"
          text="We kijken onder andere naar geluidsniveau, binnenunit, buitenunit, leidingroute en het benodigde koelvermogen. Zo krijg je een oplossing die in de praktijk prettig werkt."
        />
        <div class="mt-6 grid gap-3">
          <p class="flex items-center gap-2 text-[15px] text-black">
            <ShieldCheck size={18} class="text-brand-blue" aria-hidden="true" />
            Nette plaatsing van binnen- en buitenunit
          </p>
          <p class="flex items-center gap-2 text-[15px] text-black">
            <ThermometerSun size={18} class="text-brand-blue" aria-hidden="true" />
            Advies voor koelen en verwarmen
          </p>
          <p class="flex items-center gap-2 text-[15px] text-black">
            <CalendarCheck size={18} class="text-brand-blue" aria-hidden="true" />
            Heldere planning voor de installatiedag
          </p>
        </div>
      </div>
      <img
        src="/images/airco-advies-v2.webp"
        alt="Airco specialist controleert instellingen van een airco"
        class="h-[320px] w-full rounded-[4px] object-cover"
        loading="lazy"
      />
    </div>
  </section>

  <section id="reviews" class="bg-white section-pad">
    <div class="container-page">
      <SectionIntro
        eyebrow="Reviews"
        title="Wat klanten waarderen"
        text="Korte ervaringen van klanten die een airco hebben laten plaatsen."
        centered={true}
      />

      <div class="mt-8 grid gap-5 md:grid-cols-3">
        {reviews.map((review) => (
          <article class="service-card p-6">
            <div class="mb-3 flex gap-1 text-brand-orange" aria-label="5 sterren">
              {[1, 2, 3, 4, 5].map(() => <Star size={16} fill="currentColor" aria-hidden="true" />)}
            </div>
            <p class="text-[15px] leading-7 text-black">“{review.text}”</p>
            <p class="mt-4 font-bold text-brand-deep">{review.name}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section id="offerte" class="bg-brand-soft section-pad">
    <div class="container-page grid gap-8 lg:grid-cols-[0.8fr_1fr]">
      <div>
        <SectionIntro
          eyebrow="Contact"
          title="Vraag gratis airco advies aan"
          text="Vul het formulier in en vertel kort waar je een airco wilt plaatsen. We nemen contact op voor advies en een duidelijke prijsindicatie."
        />
        <div class="cable-corner-left mt-6 border border-l-4 border-brand-orange bg-white p-5 text-[15px] leading-7 text-black">
          Handig om alvast te vermelden: welke ruimte je wilt koelen, hoeveel kamers het zijn en of er al een buitenunitplek is.
        </div>
      </div>
      <LeadForm />
    </div>
  </section>

  <section class="bg-white section-pad">
    <div class="container-page grid gap-8 lg:grid-cols-[0.85fr_1fr]">
      <SectionIntro
        eyebrow="Veelgestelde vragen"
        title="Vragen over airco installatie"
        text="Een paar praktische antwoorden voordat je een aanvraag doet."
      />
      <div class="grid gap-3">
        {faqs.map((faq) => (
          <details class="service-card cable-corner p-5">
            <summary class="cursor-pointer text-[17px] font-bold text-brand-deep">{faq.q}</summary>
            <p class="mt-3 text-[15px] leading-7 text-black">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    mainEntity: faqs.map((faq) => ({
      "@type": "Question",
      name: faq.q,
      acceptedAnswer: {
        "@type": "Answer",
        text: faq.a,
      },
    })),
  })}></script>
</BaseLayout>
