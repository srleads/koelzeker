---
import { Mail, Phone } from "@lucide/astro";
---

<footer class="bg-[#101820] text-white">
  <div class="container-page grid gap-10 py-12 md:grid-cols-[1.4fr_1fr_1fr]">
    <div>
      <a href="/" class="inline-flex items-center">
        <img src="/images/koelzeker-logo.webp" alt="Koelzeker Klimaatspecialist" class="h-[56px] w-auto max-w-[260px] object-contain brightness-0 invert" />
      </a>
      <p class="mt-5 max-w-md text-sm leading-7 text-white">
        Airco advies, installatie en onderhoud voor particuliere woningen en kleinzakelijke adressen.
      </p>
    </div>

    <div>
      <h2 class="text-[13px] font-extrabold uppercase text-white">Contact</h2>
      <div class="mt-4 grid gap-3 text-sm text-white">
        <a class="inline-flex items-center gap-2 hover:text-white" href="tel:+31850604490">
          <Phone size={16} aria-hidden="true" />
          085 060 44 90
        </a>
        <a class="inline-flex items-center gap-2 hover:text-white" href="mailto:info@koelzeker.nl">
          <Mail size={16} aria-hidden="true" />
          info@koelzeker.nl
        </a>
      </div>
    </div>

    <div>
      <h2 class="text-[13px] font-extrabold uppercase text-white">Beeldbronnen</h2>
      <p class="mt-4 text-sm leading-7 text-white">
        Foto's via Wikimedia Commons en het aangeleverde Koelzeker-logo.
      </p>
    </div>
  </div>
  <div class="border-t border-white/10">
    <div class="container-page flex flex-col gap-2 py-5 text-xs text-white sm:flex-row sm:items-center sm:justify-between">
      <p>© 2026 Koelzeker Klimaatspecialist. Alle rechten voorbehouden.</p>
      <p>Gebouwd voor Netlify Forms en snelle SEO-indexatie.</p>
    </div>
  </div>
</footer>
