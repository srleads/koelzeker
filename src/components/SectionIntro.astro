---
const { eyebrow, title, text, centered = false, inverted = false } = Astro.props;

const wrapperClass = centered ? "mx-auto max-w-3xl text-center" : "max-w-3xl";
const titleClass = inverted
  ? "mt-3 text-[32px] font-extrabold leading-tight text-white sm:text-[42px]"
  : "section-title mt-3";
const textClass = inverted
  ? "mx-auto mt-4 max-w-2xl text-[16px] leading-7 text-white"
  : "section-copy mt-4";
---

<div class={wrapperClass}>
  <p class="section-eyebrow">{eyebrow}</p>
  <h2 class={titleClass}>{title}</h2>
  {text && <p class={textClass}>{text}</p>}
</div>
